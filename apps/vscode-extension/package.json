{
  "name": "debugiq",
  "displayName": "DebugIQ",
  "description": "AI-aware debugging for teams that use AI to code",
  "version": "0.1.0",
  "private": true,
  "publisher": "debugiq",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugiq.runDemo",
        "title": "DebugIQ: Run Demo Analysis"
      },
      {
        "command": "debugiq.login",
        "title": "DebugIQ: Log In"
      },
      {
        "command": "debugiq.logout",
        "title": "DebugIQ: Log Out"
      }
    ],
    "configuration": {
      "title": "DebugIQ",
      "properties": {
        "debugiq.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "DebugIQ backend URL. Leave empty to use the default production URL set at build time."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@debugiq/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
