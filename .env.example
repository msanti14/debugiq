# DebugIQ — Environment Variables Template
# Copy this file to .env for local development.
# NEVER put real values here. NEVER commit .env.

# ── Backend ──────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically in production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/debugiq

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token lifetimes (seconds)
ACCESS_TOKEN_EXPIRE_SECONDS=900
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_ENV=development           # development | production
APP_VERSION=0.1.0

# ── VS Code Extension ─────────────────────────────────────
# Base URL of the deployed FastAPI backend.
# Phase 0: use Railway-generated URL (e.g. https://debugiq-api-production.up.railway.app)
# Phase 1+: replace with confirmed custom domain.
API_BASE_URL=http://localhost:8000

# Feature flags
DEMO_MODE_ENABLED=true
